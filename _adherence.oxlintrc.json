{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/navigation/**",
              "components/study/**",
              "redesign/**",
              "redesign/app/**",
              "ui_kits/portal/**",
              "ui_kits/study/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='CrumbItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<CrumbItem> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|icon|as|href|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, icon, as, href, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|slides)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'slides'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DisciplineCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:discipline|emoji|title|description|footer|href|onClick|key|ref|className|style|children)$/]",
        "message": "<DisciplineCard> doesn't accept that prop. Declared props: discipline, emoji, title, description, footer, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExamBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|exam|size|style|key|ref|className|style|children)$/]",
        "message": "<ExamBadge> doesn't accept that prop. Declared props: children, exam, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExamBadge'] > JSXAttribute[name.name='exam'] > Literal[value!=/^(?:p1|p2)$/]",
        "message": "<ExamBadge> exam must be one of 'p1' | 'p2'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Flashcard'] > JSXAttribute > JSXIdentifier[name!=/^(?:front|back|height|flipped|onFlip|frontHint|backHint|key|ref|className|style|children)$/]",
        "message": "<Flashcard> doesn't accept that prop. Declared props: front, back, height, flipped, onFlip, frontHint, backHint."
      },
      {
        "selector": "JSXOpeningElement[name.name='FonteTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<FonteTag> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IntroBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|icon|accent|children|sources|key|ref|className|style|children)$/]",
        "message": "<IntroBox> doesn't accept that prop. Declared props: title, icon, accent, children, sources."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:letter|children|status|answered|onClick|key|ref|className|style|children)$/]",
        "message": "<OptionButton> doesn't accept that prop. Declared props: letter, children, status, answered, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionButton'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:idle|correct|wrong|dimmed)$/]",
        "message": "<OptionButton> status must be one of 'idle' | 'correct' | 'wrong' | 'dimmed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:p1|p2|ok|neutral)$/]",
        "message": "<Pill> tone must be one of 'p1' | 'p2' | 'ok' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|tagline|logoEmoji|children|width|style|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: brand, tagline, logoEmoji, children, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopicCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|exam|discipline|title|subtitle|tags|href|onClick|key|ref|className|style|children)$/]",
        "message": "<TopicCard> doesn't accept that prop. Declared props: number, exam, discipline, title, subtitle, tags, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopicCard'] > JSXAttribute[name.name='exam'] > Literal[value!=/^(?:p1|p2)$/]",
        "message": "<TopicCard> exam must be one of 'p1' | 'p2'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
